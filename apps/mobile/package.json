{
  "name": "@bilisound/mobile",
  "main": "expo-router/entry",
  "version": "2.3.0",
  "scripts": {
    "start": "expo start -c --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start -c --web",
    "prepare": "pnpm run generate-license",
    "test": "jest --watchAll",
    "build:android": "cross-env EXPO_PUBLIC_ENV=production NODE_ENV=production tsx ./scripts/run-gradle.mts assembleRelease",
    "build:web": "expo export --platform web",
    "lint": "eslint --fix .",
    "generate-migration": "drizzle-kit generate",
    "generate-license": "generate-license-file --input package.json --output third-party-licenses.txt --overwrite --ci",
    "clean": "node -e \"const opt = { recursive: true, force: true }; fs.rmSync('./ios', opt); fs.rmSync('./android', opt); fs.rmSync('./node_modules/.cache', opt)\"",
    "open:ios": "xed ios",
    "open:android": "open -a \"Android Studio\" android",
    "prebuild": "expo prebuild",
    "prebuild:local": "watchman watch-del-all && expo prebuild"
  },
  "jest": {
    "preset": "jest-expo"
  },
